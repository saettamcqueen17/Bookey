<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amici e Richieste"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <!-- Sezione tab per passare tra Richieste e Amici -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/friendTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Richieste" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amici" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Contenuto Richieste in arrivo -->
    <LinearLayout
        android:id="@+id/requestsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/noRequestsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessuna richiesta in sospeso"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/friendRequestsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="300dp"
            android:scrollbars="vertical" />

    </LinearLayout>

    <!-- Contenuto lista Amici (per aprire la chat) -->
    <LinearLayout
        android:id="@+id/friendsListSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/noFriendsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessun amico ancora"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/friendsListRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="300dp"
            android:scrollbars="vertical" />

    </LinearLayout>

</LinearLayout>

